{
  "name": "agentscope",
  "version": "0.1.0",
  "description": "AI Agent 的'X光机'——让 Agent 的每一步决策、每一次工具调用都清晰可见",
  "keywords": [
    "ai",
    "agent",
    "debugging",
    "visualization",
    "openclaw",
    "langchain",
    "autogen",
    "llm",
    "observability"
  ],
  "author": "AgentScope Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/JOEH60/agentscope.git"
  },
  "bugs": {
    "url": "https://github.com/JOEH60/agentscope/issues"
  },
  "homepage": "https://github.com/JOEH60/agentscope#readme",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "agentscope": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./core": {
      "import": "./dist/core/index.js",
      "types": "./dist/core/index.d.ts"
    },
    "./adapters": {
      "import": "./dist/adapters/index.js",
      "types": "./dist/adapters/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx watch src/cli/index.ts",
    "build": "tsup",
    "start": "node dist/cli/index.js",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "express": "^4.21.0",
    "ws": "^8.18.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ora": "^8.1.0",
    "boxen": "^8.0.0",
    "better-sqlite3": "^11.0.0",
    "zod": "^3.23.0",
    "uuid": "^10.0.0",
    "dayjs": "^1.11.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "tsup": "^8.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
